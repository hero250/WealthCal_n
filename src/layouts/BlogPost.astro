---
import Base from './Base.astro';
export interface Props {
  title: string;
  description: string;
  pubDate: string;
  category: string;
  readTime: string;
  calculatorLink?: string;
  calculatorLabel?: string;
}
const { title, description, pubDate, category, readTime, calculatorLink, calculatorLabel } = Astro.props;
const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": pubDate,
  "author": {"@type": "Organization", "name": "WealthCalc"},
  "publisher": {"@type": "Organization", "name": "WealthCalc", "url": "https://www.wealthcal.org"}
});
---
<Base title={`${title} | WealthCalc`} description={description}>
  <script type="application/ld+json" set:html={schema}/>
  <style>
    .art-hero{padding:3.5rem 2rem 2rem;border-bottom:1px solid var(--border);position:relative;z-index:1;max-width:760px;margin:0 auto}
    .art-cat{font-size:.65rem;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:var(--green);margin-bottom:.85rem}
    .art-h1{font-family:'Syne',sans-serif;font-size:clamp(1.9rem,4vw,2.8rem);font-weight:800;line-height:1.1;letter-spacing:-1.5px;margin-bottom:.85rem}
    .art-meta{color:var(--text3);font-size:.78rem;display:flex;gap:1rem;align-items:center;flex-wrap:wrap}
    .art-meta span{display:flex;align-items:center;gap:.3rem}
    .art-body{max-width:760px;margin:0 auto;padding:2.5rem 2rem 4rem;position:relative;z-index:1}
    .art-body h2{font-family:'Syne',sans-serif;font-size:1.4rem;font-weight:700;margin:2.25rem 0 .85rem;letter-spacing:-.5px}
    .art-body h3{font-family:'Syne',sans-serif;font-size:1.1rem;font-weight:700;margin:1.75rem 0 .65rem}
    .art-body p{font-size:.95rem;line-height:1.85;color:var(--text2);margin-bottom:1.1rem}
    .art-body ul,.art-body ol{padding-left:1.4rem;margin-bottom:1.1rem}
    .art-body li{font-size:.95rem;line-height:1.8;color:var(--text2);margin-bottom:.35rem}
    .art-body strong{color:var(--text);font-weight:600}
    .art-body a{color:var(--green);text-decoration:underline;text-underline-offset:3px}
    .art-body pre{background:var(--navy3);border:1px solid var(--border);border-radius:var(--radius-sm);padding:1.1rem 1.35rem;margin:1.35rem 0;font-family:monospace;font-size:.85rem;color:var(--green);overflow-x:auto;white-space:pre;line-height:1.7}
    .callout{background:rgba(0,229,160,.06);border:1px solid rgba(0,229,160,.18);border-left:3px solid var(--green);border-radius:var(--radius-sm);padding:1.1rem 1.35rem;margin:1.35rem 0}
    .callout p{margin:0;color:var(--text);font-size:.9rem}
    .cta-box{background:linear-gradient(135deg,rgba(0,229,160,.1),rgba(0,229,160,.03));border:1px solid rgba(0,229,160,.2);border-radius:var(--radius);padding:1.75rem;text-align:center;margin:2.25rem 0}
    .cta-box h3{font-family:'Syne',sans-serif;font-size:1.2rem;font-weight:700;margin-bottom:.4rem}
    .cta-box p{font-size:.85rem;color:var(--text3);margin-bottom:1.1rem}
    .cta-box a{background:var(--green);color:var(--navy);border:none;padding:.7rem 1.75rem;border-radius:var(--radius-sm);font-weight:700;font-size:.9rem;font-family:'Syne',sans-serif;display:inline-block;transition:background .2s}
    .cta-box a:hover{background:var(--green2);text-decoration:none}
    .related{max-width:760px;margin:0 auto;padding:0 2rem 3rem;position:relative;z-index:1}
    .related h3{font-family:'Syne',sans-serif;font-size:1rem;font-weight:700;margin-bottom:1rem;color:var(--text3);letter-spacing:1px;text-transform:uppercase;font-size:.72rem}
    .related-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem}
    .related-card{background:var(--navy2);border:1px solid var(--border);border-radius:var(--radius);padding:1.1rem;transition:all .2s}
    .related-card:hover{border-color:rgba(0,229,160,.3);transform:translateY(-2px)}
    .related-card span{font-size:.65rem;color:var(--green);text-transform:uppercase;letter-spacing:1.5px;font-weight:700}
    .related-card p{font-size:.85rem;font-weight:600;margin-top:.3rem;color:var(--text);font-family:'Syne',sans-serif}
  </style>

  <article>
    <div class="art-hero">
      <div class="art-cat">{category}</div>
      <h1 class="art-h1">{title}</h1>
      <div class="art-meta">
        <span>📅 {pubDate}</span>
        <span>⏱ {readTime}</span>
        <span>✍️ WealthCalc Editorial</span>
      </div>
    </div>

    <div class="art-body">
      <slot/>
      {calculatorLink && (
        <div class="cta-box">
          <h3>Run the Numbers Yourself</h3>
          <p>Use our free calculator to see the math for your exact situation — no sign-up needed.</p>
          <a href={calculatorLink}>{calculatorLabel || 'Open Calculator →'}</a>
        </div>
      )}
    </div>

    <div class="related">
      <h3>More from WealthCalc</h3>
      <div class="related-grid">
        <a href="/blog/fire-calculator-guide" class="related-card"><span>Money Basics</span><p>The Complete FIRE Guide</p></a>
        <a href="/blog/how-much-house-can-i-afford" class="related-card"><span>Mortgage</span><p>How Much House Can You Afford?</p></a>
        <a href="/blog/401k-mistakes" class="related-card"><span>Retirement</span><p>7 Costly 401(k) Mistakes</p></a>
        <a href="/blog/pay-off-mortgage-vs-invest" class="related-card"><span>Debt</span><p>Mortgage Payoff vs Invest</p></a>
      </div>
    </div>
  </article>
</Base>
