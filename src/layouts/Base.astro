---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
}
const { title, description, canonical } = Astro.props;
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{title}</title>
  <meta name="description" content={description}/>
  <meta name="robots" content="index, follow"/>
  <link rel="canonical" href={canonicalURL}/>
  <meta property="og:title" content={title}/>
  <meta property="og:description" content={description}/>
  <meta property="og:type" content="website"/>
  <meta property="og:url" content={canonicalURL}/>
  <link rel="sitemap" href="/sitemap-index.xml"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Instrument+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style is:global>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --navy:#060d1f;--navy2:#0c1830;--navy3:#112040;
      --border:#1e3358;--border2:#2a4472;
      --green:#00e5a0;--green2:#00c285;
      --green-dim:rgba(0,229,160,0.08);--green-glow:rgba(0,229,160,0.15);
      --text:#f0f4ff;--text2:#a8b8d8;--text3:#6a7fa8;
      --gold:#f5c842;--red:#ff5e5e;--blue:#4d9fff;--purple:#b57bff;
      --radius:14px;--radius-sm:8px;
    }
    html{scroll-behavior:smooth}
    body{font-family:'Instrument Sans',sans-serif;background:var(--navy);color:var(--text);min-height:100vh;overflow-x:hidden}
    body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
      background:radial-gradient(ellipse 80% 50% at 20% 0%,rgba(0,229,160,.04) 0%,transparent 60%),
                 radial-gradient(ellipse 60% 40% at 80% 100%,rgba(77,159,255,.04) 0%,transparent 60%)}
    @keyframes fadeUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
    a{color:inherit;text-decoration:none}

    /* NAV */
    nav{position:sticky;top:0;z-index:100;background:rgba(6,13,31,.92);backdrop-filter:blur(24px);
      border-bottom:1px solid var(--border);padding:0 2rem;display:flex;align-items:center;justify-content:space-between;height:60px}
    .logo{font-family:'Syne',sans-serif;font-size:1.3rem;font-weight:800;color:var(--text);display:flex;align-items:center;gap:.4rem}
    .logo-dot{width:7px;height:7px;background:var(--green);border-radius:50%}
    .nav-links{display:flex;gap:.1rem;list-style:none}
    .nav-links a{color:var(--text3);font-size:.82rem;font-weight:500;padding:.4rem .85rem;border-radius:var(--radius-sm);transition:all .2s}
    .nav-links a:hover{color:var(--text);background:var(--navy3)}
    .nav-links a.active{color:var(--green);background:var(--green-dim)}
    .nav-cta{background:var(--green);color:var(--navy);border:none;padding:.4rem 1rem;border-radius:var(--radius-sm);font-family:'Instrument Sans',sans-serif;font-size:.82rem;font-weight:600;cursor:pointer;transition:all .2s;text-decoration:none}
    .nav-cta:hover{background:var(--green2)}

    /* FOOTER */
    footer{background:var(--navy2);border-top:1px solid var(--border);padding:2rem;text-align:center;position:relative;z-index:1;margin-top:4rem}
    .footer-logo{font-family:'Syne',sans-serif;font-size:1.1rem;font-weight:800;color:var(--text);margin-bottom:.4rem;display:flex;align-items:center;gap:.3rem;justify-content:center}
    .footer-dot{width:5px;height:5px;background:var(--green);border-radius:50%}
    footer p{font-size:.75rem;color:var(--text3);margin-top:.25rem}
    footer nav{position:static;background:none;border:none;height:auto;padding:0;justify-content:center;gap:1.5rem;margin-top:.75rem}
    footer nav a{color:var(--text3);font-size:.78rem;transition:color .2s}
    footer nav a:hover{color:var(--green)}

    @media(max-width:640px){.nav-links{display:none}}
  </style>
</head>
<body>
  <nav>
    <a href="/" class="logo"><span class="logo-dot"></span>WealthCalc</a>
    <ul class="nav-links">
      <li><a href="/" class={Astro.url.pathname === '/' ? 'active' : ''}>Calculators</a></li>
      <li><a href="/blog" class={Astro.url.pathname.startsWith('/blog') ? 'active' : ''}>Blog</a></li>
    </ul>
    <a href="/#calculators" class="nav-cta">Try a Calculator</a>
  </nav>

  <slot/>

  <footer>
    <div class="footer-logo"><span class="footer-dot"></span>WealthCalc</div>
    <p>Free US financial calculators. For educational purposes only — not financial advice.</p>
    <p>© 2026 WealthCalc · wealthcal.org</p>
    <nav>
      <a href="/">Calculators</a>
      <a href="/blog">Blog</a>
      <a href="/blog/fire-calculator-guide">FIRE Guide</a>
      <a href="/blog/how-much-house-can-i-afford">Mortgage Guide</a>
      <a href="/blog/401k-mistakes">401(k) Guide</a>
    </nav>
  </footer>
</body>
</html>
