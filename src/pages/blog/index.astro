---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);
const featured = posts[0];
const rest = posts.slice(1);
---
<Base title="WealthCalc Blog – Financial Guides for Americans" description="Expert guides on mortgages, 401k, FIRE, paycheck taxes, retirement planning and more. Free, jargon-free financial intelligence for Americans.">
<style>
  .blog-hero{padding:4rem 2rem 2.5rem;text-align:center;border-bottom:1px solid var(--border);position:relative;z-index:1}
  .eyebrow{font-size:.7rem;text-transform:uppercase;letter-spacing:3px;color:var(--green);margin-bottom:.75rem;font-weight:600}
  .blog-h1{font-family:'Syne',sans-serif;font-size:clamp(2rem,5vw,3.2rem);font-weight:800;letter-spacing:-2px;line-height:1.08;margin-bottom:.85rem}
  .blog-h1 span{color:var(--green)}
  .blog-sub{color:var(--text2);max-width:460px;margin:0 auto 2rem;font-size:.95rem;line-height:1.7}
  .filters{display:flex;gap:.5rem;flex-wrap:wrap;justify-content:center}
  .filter-btn{background:var(--navy2);border:1px solid var(--border);color:var(--text3);padding:.42rem 1rem;border-radius:100px;font-size:.78rem;font-weight:500;font-family:'Instrument Sans',sans-serif;cursor:pointer;transition:all .2s}
  .filter-btn:hover,.filter-btn.active{border-color:var(--green);color:var(--green);background:var(--green-dim)}
  .blog-wrap{max-width:1060px;margin:0 auto;padding:2.5rem 1.5rem 5rem;display:grid;grid-template-columns:1fr 280px;gap:2.5rem;align-items:start;position:relative;z-index:1}
  .featured{background:var(--navy2);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:1.5rem;display:grid;grid-template-columns:1fr 1fr;transition:all .25s}
  .featured:hover{border-color:rgba(0,229,160,.3);transform:translateY(-2px)}
  .feat-vis{background:linear-gradient(135deg,#061428 0%,#0c2040 60%,#092030 100%);display:flex;align-items:center;justify-content:center;font-size:4.5rem;position:relative;min-height:240px}
  .feat-vis::after{content:'FEATURED';position:absolute;top:.85rem;left:.85rem;font-size:.6rem;font-weight:700;letter-spacing:2.5px;color:var(--green);background:var(--green-dim);border:1px solid rgba(0,229,160,.25);padding:.25rem .7rem;border-radius:100px}
  .feat-body{padding:1.75rem;display:flex;flex-direction:column;justify-content:center}
  .post-cat{font-size:.65rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;margin-bottom:.65rem;color:var(--green)}
  .post-title{font-family:'Syne',sans-serif;font-size:1.2rem;font-weight:700;line-height:1.25;margin-bottom:.65rem;letter-spacing:-.5px;color:var(--text)}
  .post-excerpt{font-size:.82rem;color:var(--text3);line-height:1.7;margin-bottom:1rem}
  .post-meta{display:flex;align-items:center;gap:.75rem;font-size:.7rem;color:var(--text3)}
  .post-read{color:var(--green);font-weight:600;margin-left:auto;font-size:.75rem}
  .posts-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.1rem}
  .post-card{background:var(--navy2);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;transition:all .25s}
  .post-card:hover{border-color:rgba(0,229,160,.3);transform:translateY(-3px)}
  .card-vis{height:100px;display:flex;align-items:center;justify-content:center;font-size:2.5rem;background:linear-gradient(135deg,var(--navy3),var(--navy2))}
  .card-body{padding:1.1rem}
  .card-body .post-title{font-size:.92rem;margin-bottom:.4rem}
  .card-body .post-excerpt{font-size:.75rem;margin-bottom:.6rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
  /* SIDEBAR */
  .sidebar{display:flex;flex-direction:column;gap:1.25rem}
  .sb-card{background:var(--navy2);border:1px solid var(--border);border-radius:var(--radius);padding:1.25rem}
  .sb-title{font-family:'Syne',sans-serif;font-size:.9rem;font-weight:700;margin-bottom:1rem;padding-bottom:.75rem;border-bottom:1px solid var(--border)}
  .sb-cta{background:linear-gradient(135deg,rgba(0,229,160,.12),rgba(0,229,160,.04));border:1px solid rgba(0,229,160,.2)!important}
  .sb-btn{display:block;width:100%;padding:.65rem;background:var(--green);color:var(--navy);border:none;border-radius:var(--radius-sm);font-family:'Syne',sans-serif;font-size:.82rem;font-weight:700;cursor:pointer;text-align:center;transition:all .2s;text-decoration:none}
  .sb-btn:hover{background:var(--green2)}
  .pop-list{display:flex;flex-direction:column;gap:.85rem}
  .pop-item{display:flex;gap:.65rem;align-items:flex-start}
  .pop-num{font-family:'Syne',sans-serif;font-size:1rem;font-weight:800;color:var(--green);flex-shrink:0;width:18px}
  .pop-text{font-size:.78rem;line-height:1.5;color:var(--text2)}
  .pop-item:hover .pop-text{color:var(--green)}
  .tag-cloud{display:flex;flex-wrap:wrap;gap:.4rem}
  .tag{background:var(--navy);border:1px solid var(--border);color:var(--text3);padding:.25rem .65rem;border-radius:100px;font-size:.7rem;transition:all .2s}
  .tag:hover{border-color:var(--green);color:var(--green)}
  .nl-input{width:100%;background:var(--navy);border:1px solid var(--border);border-radius:var(--radius-sm);padding:.65rem .9rem;color:var(--text);font-family:'Instrument Sans',sans-serif;font-size:.85rem;outline:none;margin-bottom:.65rem;transition:border-color .2s}
  .nl-input:focus{border-color:var(--green)}
  .nl-input::placeholder{color:var(--text3)}
  @media(max-width:900px){.blog-wrap{grid-template-columns:1fr}.sidebar{order:-1}}
  @media(max-width:600px){.posts-grid{grid-template-columns:1fr}.featured{grid-template-columns:1fr}.feat-vis{min-height:130px;font-size:3rem}}
</style>

<section class="blog-hero">
  <p class="eyebrow">Smart Money · Plain English</p>
  <h1 class="blog-h1">The <span>Financial</span><br/>Intelligence Blog</h1>
  <p class="blog-sub">Guides and strategies to help Americans make smarter decisions about mortgages, retirement, taxes, and wealth.</p>
  <div class="filters">
    <button class="filter-btn active" onclick="filterPosts('all',this)">All</button>
    <button class="filter-btn" onclick="filterPosts('Mortgage',this)">Mortgage</button>
    <button class="filter-btn" onclick="filterPosts('Retirement',this)">Retirement</button>
    <button class="filter-btn" onclick="filterPosts('Paycheck',this)">Paycheck & Tax</button>
    <button class="filter-btn" onclick="filterPosts('Basics',this)">Money Basics</button>
    <button class="filter-btn" onclick="filterPosts('Debt',this)">Debt</button>
  </div>
</section>

<div class="blog-wrap">
  <main>
    {featured && (
      <a href={`/blog/${featured.slug}`} class="featured">
        <div class="feat-vis">{featured.data.emoji}</div>
        <div class="feat-body">
          <div class="post-cat">{featured.data.category}</div>
          <div class="post-title">{featured.data.title}</div>
          <p class="post-excerpt">{featured.data.description}</p>
          <div class="post-meta">
            <span>{featured.data.readTime}</span>
            <span>·</span>
            <span>{featured.data.pubDate}</span>
            <span class="post-read">Read Article →</span>
          </div>
        </div>
      </a>
    )}

    <div class="posts-grid" id="posts-grid">
      {rest.map(post => (
        <a href={`/blog/${post.slug}`} class="post-card" data-cat={post.data.category}>
          <div class="card-vis">{post.data.emoji}</div>
          <div class="card-body">
            <div class="post-cat">{post.data.category}</div>
            <div class="post-title">{post.data.title}</div>
            <p class="post-excerpt">{post.data.description}</p>
            <div class="post-meta">
              <span>{post.data.readTime}</span>
              <span class="post-read">Read →</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </main>

  <aside class="sidebar">
    <div class="sb-card sb-cta">
      <p style="font-size:1.75rem;margin-bottom:.6rem">⚡</p>
      <p style="font-family:'Syne',sans-serif;font-weight:700;margin-bottom:.4rem">Run the Numbers</p>
      <p style="font-size:.78rem;color:var(--text3);line-height:1.6;margin-bottom:.85rem">Every article links to a free calculator for your exact situation.</p>
      <a href="/#calculators" class="sb-btn">Open Calculators →</a>
    </div>
    <div class="sb-card">
      <div class="sb-title">🔥 Most Read</div>
      <div class="pop-list">
        {posts.slice(0,5).map((post, i) => (
          <a href={`/blog/${post.slug}`} class="pop-item">
            <span class="pop-num">0{i+1}</span>
            <span class="pop-text">{post.data.title}</span>
          </a>
        ))}
      </div>
    </div>
    <div class="sb-card">
      <div class="sb-title">📬 Weekly Digest</div>
      <p style="font-size:.78rem;color:var(--text3);margin-bottom:.85rem;line-height:1.6">One money insight per week. No spam.</p>
      <input class="nl-input" type="email" placeholder="your@email.com"/>
      <button class="sb-btn">Subscribe Free →</button>
    </div>
    <div class="sb-card">
      <div class="sb-title">🏷️ Topics</div>
      <div class="tag-cloud">
        <span class="tag">Mortgage</span><span class="tag">401(k)</span>
        <span class="tag">FIRE</span><span class="tag">Roth IRA</span>
        <span class="tag">Paycheck</span><span class="tag">Taxes</span>
        <span class="tag">Retirement</span><span class="tag">Auto Loan</span>
        <span class="tag">Compound Interest</span><span class="tag">Debt Payoff</span>
      </div>
    </div>
  </aside>
</div>

<script>
function filterPosts(cat, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.post-card').forEach(c => {
    c.style.display = (cat === 'all' || c.dataset.cat === cat) ? '' : 'none';
  });
}
</script>
</Base>
