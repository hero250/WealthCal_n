---
import Base from '../layouts/Base.astro';
---
<Base
  title="WealthCalc – Free Financial Calculators for Americans 2026"
  description="Free US financial calculators: mortgage, paycheck, 401k, compound interest, auto loan, retirement, FIRE, and CD. Instant results, no sign-up required."
>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"WebApplication","name":"WealthCalc","description":"Free US financial calculators for mortgage, paycheck, 401k, retirement, FIRE and more.","applicationCategory":"FinanceApplication","offers":{"@type":"Offer","price":"0","priceCurrency":"USD"}}</script>

<style>
  *{box-sizing:border-box}
  :root{--radius:14px;--radius-sm:8px}
  @keyframes fadeUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
  @keyframes pulse{0%,100%{opacity:.6}50%{opacity:1}}

  /* HERO */
  .hero{padding:5rem 2rem 3rem;text-align:center;position:relative;overflow:hidden;z-index:1}
  .hero-line{position:absolute;top:0;left:50%;transform:translateX(-50%);width:1px;height:100px;background:linear-gradient(to bottom,var(--green),transparent);opacity:.4}
  .hero-badge{display:inline-flex;align-items:center;gap:.5rem;font-size:.72rem;font-weight:500;letter-spacing:2px;text-transform:uppercase;color:var(--green);border:1px solid rgba(0,229,160,.25);padding:.35rem 1rem;border-radius:100px;margin-bottom:1.5rem;animation:fadeUp .6s ease both}
  .badge-dot{width:5px;height:5px;background:var(--green);border-radius:50%;animation:pulse 1.5s infinite}
  h1{font-family:'Syne',sans-serif;font-size:clamp(2.8rem,6vw,5rem);font-weight:800;line-height:1.0;letter-spacing:-3px;margin-bottom:1.25rem;animation:fadeUp .6s .1s ease both}
  .accent{color:var(--green)}.dim{color:var(--text2)}
  .hero-sub{font-size:1.05rem;color:var(--text2);max-width:520px;margin:0 auto 2.5rem;line-height:1.7;font-weight:300;animation:fadeUp .6s .2s ease both}
  .stats-row{display:flex;justify-content:center;max-width:500px;margin:0 auto 3rem;border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;animation:fadeUp .6s .3s ease both}
  .stat{flex:1;padding:1rem;text-align:center;border-right:1px solid var(--border)}
  .stat:last-child{border-right:none}
  .stat-num{font-family:'Syne',sans-serif;font-size:1.4rem;font-weight:800;color:var(--green)}
  .stat-label{font-size:.7rem;color:var(--text3);margin-top:2px;letter-spacing:.5px;text-transform:uppercase}

  /* CALC PILLS */
  .calc-nav{max-width:980px;margin:0 auto;padding:0 1.5rem 1.5rem;display:flex;gap:.5rem;flex-wrap:wrap;justify-content:center;animation:fadeUp .6s .4s ease both;position:relative;z-index:1}
  .calc-pill{background:var(--navy2);border:1px solid var(--border);color:var(--text3);padding:.5rem 1.1rem;border-radius:100px;font-size:.8rem;font-weight:500;font-family:'Instrument Sans',sans-serif;cursor:pointer;transition:all .2s;white-space:nowrap}
  .calc-pill:hover{border-color:var(--green);color:var(--text)}
  .calc-pill.active{background:var(--green-dim);border-color:var(--green);color:var(--green)}

  /* CALC CARDS */
  .calc-area{max-width:980px;margin:0 auto;padding:0 1.5rem 5rem;position:relative;z-index:1}
  .calc-card{background:var(--navy2);border:1px solid var(--border);border-radius:var(--radius);padding:2.5rem;display:none;animation:fadeUp .3s ease both;position:relative;overflow:hidden}
  .calc-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(to right,var(--green),transparent)}
  .calc-card.active{display:block}
  .calc-icon{font-size:1.8rem;margin-bottom:.75rem}
  .calc-title{font-family:'Syne',sans-serif;font-size:1.5rem;font-weight:700;letter-spacing:-.5px;margin-bottom:.3rem}
  .calc-desc{color:var(--text3);font-size:.88rem;line-height:1.6;margin-bottom:2rem}
  .calc-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;margin-bottom:1.5rem}
  .field{display:flex;flex-direction:column;gap:.45rem}
  .field label{font-size:.72rem;font-weight:500;color:var(--text3);text-transform:uppercase;letter-spacing:.8px}
  .field input,.field select{background:var(--navy3);border:1px solid var(--border);border-radius:var(--radius-sm);padding:.75rem 1rem;color:var(--text);font-family:'Instrument Sans',sans-serif;font-size:.95rem;outline:none;transition:border-color .2s;width:100%}
  .field input:focus,.field select:focus{border-color:var(--green)}
  .field input::placeholder{color:var(--text3)}
  .field select option{background:var(--navy3)}
  .pfx{position:relative}
  .pfx .px{position:absolute;left:.85rem;top:50%;transform:translateY(-50%);color:var(--text3);font-size:.95rem;pointer-events:none}
  .pfx input{padding-left:1.75rem}
  .full{grid-column:span 2}
  .slider-wrap{display:flex;flex-direction:column;gap:.45rem}
  .slider-top{display:flex;justify-content:space-between;align-items:center}
  .slider-top label{font-size:.72rem;font-weight:500;color:var(--text3);text-transform:uppercase;letter-spacing:.8px}
  .sv{font-size:.88rem;font-weight:600;color:var(--green);font-family:'Syne',sans-serif}
  input[type=range]{-webkit-appearance:none;width:100%;height:3px;background:var(--border);border-radius:2px;outline:none}
  input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:16px;height:16px;border-radius:50%;background:var(--green);cursor:pointer;border:2px solid var(--navy);box-shadow:0 0 0 3px var(--green-glow)}
  .calc-btn{width:100%;padding:.9rem;background:var(--green);color:var(--navy);border:none;border-radius:var(--radius-sm);font-family:'Syne',sans-serif;font-size:.95rem;font-weight:700;cursor:pointer;transition:all .2s;letter-spacing:.3px}
  .calc-btn:hover{background:var(--green2);transform:translateY(-1px);box-shadow:0 8px 28px rgba(0,229,160,.2)}
  .result-box{margin-top:1.5rem;background:var(--green-dim);border:1px solid rgba(0,229,160,.18);border-radius:var(--radius);padding:1.5rem 2rem;display:none;animation:fadeUp .3s ease both}
  .result-box.show{display:block}
  .rl{font-size:.65rem;text-transform:uppercase;letter-spacing:2px;color:var(--green);margin-bottom:1.25rem;font-weight:600}
  .rg{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:1rem}
  .ri{text-align:center}
  .rn{font-family:'Syne',sans-serif;font-size:1.5rem;font-weight:800;color:var(--green)}
  .rs{font-size:.7rem;color:var(--text3);margin-top:3px}
  .rnote{margin-top:1rem;font-size:.78rem;color:var(--text3);padding-top:1rem;border-top:1px solid rgba(0,229,160,.12);line-height:1.6}

  /* FEATURES */
  .features{background:var(--navy2);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:5rem 2rem;text-align:center;position:relative;z-index:1}
  .eyebrow{font-size:.7rem;text-transform:uppercase;letter-spacing:3px;color:var(--green);margin-bottom:.75rem;font-weight:600}
  .sec-title{font-family:'Syne',sans-serif;font-size:clamp(1.8rem,4vw,2.6rem);font-weight:800;margin-bottom:3rem;letter-spacing:-1.5px}
  .feat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1.25rem;max-width:960px;margin:0 auto}
  .feat{background:var(--navy);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem;text-align:left;transition:all .25s}
  .feat:hover{border-color:rgba(0,229,160,.3);transform:translateY(-3px)}
  .fi{font-size:1.5rem;margin-bottom:.75rem}
  .fn{font-family:'Syne',sans-serif;font-size:.95rem;font-weight:700;margin-bottom:.35rem}
  .ft{font-size:.8rem;color:var(--text3);line-height:1.6}

  /* FAQ */
  .faq-wrap{max-width:700px;margin:0 auto;padding:5rem 2rem;position:relative;z-index:1}
  .faq-item{border-bottom:1px solid var(--border);padding:1.1rem 0}
  .faq-q{width:100%;background:none;border:none;color:var(--text);font-family:'Instrument Sans',sans-serif;font-size:.92rem;font-weight:500;text-align:left;cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:1rem}
  .faq-icon{width:22px;height:22px;border:1px solid var(--border2);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--green);font-size:.9rem;transition:all .2s}
  .faq-item.open .faq-icon{background:var(--green-dim);border-color:var(--green);transform:rotate(45deg)}
  .faq-a{font-size:.85rem;color:var(--text2);line-height:1.75;max-height:0;overflow:hidden;transition:max-height .3s ease,padding .3s}
  .faq-item.open .faq-a{max-height:300px;padding-top:.75rem}

  /* BLOG PREVIEW */
  .blog-preview{max-width:980px;margin:0 auto;padding:0 1.5rem 5rem;position:relative;z-index:1}
  .bp-header{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:1.5rem}
  .bp-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1.1rem}
  .bp-card{background:var(--navy2);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;transition:all .25s;display:block}
  .bp-card:hover{border-color:rgba(0,229,160,.3);transform:translateY(-3px)}
  .bp-vis{height:90px;display:flex;align-items:center;justify-content:center;font-size:2.5rem;background:linear-gradient(135deg,var(--navy3),var(--navy2))}
  .bp-body{padding:1rem}
  .bp-cat{font-size:.62rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--green);margin-bottom:.4rem}
  .bp-title{font-family:'Syne',sans-serif;font-size:.9rem;font-weight:700;color:var(--text);line-height:1.3}
  .view-all{color:var(--green);font-size:.82rem;font-weight:600}

  @media(max-width:640px){.calc-grid{grid-template-columns:1fr}.full{grid-column:span 1}.stats-row{gap:0}}
</style>

<section class="hero">
  <div class="hero-line"></div>
  <div class="hero-badge"><span class="badge-dot"></span>Free · No Sign-Up · Runs in Your Browser</div>
  <h1>The <span class="accent">Smarter</span> Way<br/>to <span class="dim">Do the Math</span></h1>
  <p class="hero-sub">Instant, accurate financial calculators for mortgages, paychecks, 401k, retirement, and more. Built for Americans.</p>
  <div class="stats-row">
    <div class="stat"><div class="stat-num">8</div><div class="stat-label">Calculators</div></div>
    <div class="stat"><div class="stat-num">$0</div><div class="stat-label">Cost</div></div>
    <div class="stat"><div class="stat-num">0s</div><div class="stat-label">Results</div></div>
    <div class="stat"><div class="stat-num">100%</div><div class="stat-label">Private</div></div>
  </div>
</section>

<div class="calc-nav" id="calculators">
  <button class="calc-pill active" onclick="sw('mortgage',this)">🏠 Mortgage</button>
  <button class="calc-pill" onclick="sw('paycheck',this)">💵 Paycheck</button>
  <button class="calc-pill" onclick="sw('k401',this)">📈 401(k)</button>
  <button class="calc-pill" onclick="sw('compound',this)">🔢 Compound Interest</button>
  <button class="calc-pill" onclick="sw('auto',this)">🚗 Auto Loan</button>
  <button class="calc-pill" onclick="sw('retirement',this)">🎯 Retirement</button>
  <button class="calc-pill" onclick="sw('fire',this)">🔥 FIRE</button>
  <button class="calc-pill" onclick="sw('cd',this)">🏦 CD</button>
</div>

<div class="calc-area">

  <div class="calc-card active" id="c-mortgage">
    <div class="calc-icon">🏠</div>
    <div class="calc-title">Mortgage Calculator</div>
    <p class="calc-desc">Calculate your monthly mortgage payment including principal, interest, taxes, and insurance (PITI).</p>
    <div class="calc-grid">
      <div class="field"><label>Home Price</label><div class="pfx"><span class="px">$</span><input type="number" id="m-price" value="400000"/></div></div>
      <div class="field"><label>Down Payment</label><div class="pfx"><span class="px">$</span><input type="number" id="m-down" value="80000"/></div></div>
      <div class="field"><label>Annual Interest Rate (%)</label><input type="number" id="m-rate" value="6.8" step="0.1"/></div>
      <div class="field"><label>Loan Term</label><select id="m-term"><option value="30">30 Years</option><option value="20">20 Years</option><option value="15">15 Years</option><option value="10">10 Years</option></select></div>
      <div class="field"><label>Annual Property Tax ($)</label><input type="number" id="m-tax" value="4800"/></div>
      <div class="field"><label>Annual Home Insurance ($)</label><input type="number" id="m-ins" value="1200"/></div>
    </div>
    <button class="calc-btn" onclick="calcMortgage()">Calculate Monthly Payment →</button>
    <div class="result-box" id="r-m">
      <div class="rl">📊 Mortgage Breakdown</div>
      <div class="rg">
        <div class="ri"><div class="rn" id="m-monthly">—</div><div class="rs">Monthly Payment (PITI)</div></div>
        <div class="ri"><div class="rn" id="m-pi">—</div><div class="rs">Principal & Interest</div></div>
        <div class="ri"><div class="rn" id="m-ti">—</div><div class="rs">Total Interest Paid</div></div>
        <div class="ri"><div class="rn" id="m-tc">—</div><div class="rs">Total Cost of Home</div></div>
      </div>
      <div class="rnote" id="m-note"></div>
    </div>
  </div>

  <div class="calc-card" id="c-paycheck">
    <div class="calc-icon">💵</div>
    <div class="calc-title">Paycheck Calculator</div>
    <p class="calc-desc">Estimate your take-home pay after federal taxes, Social Security, Medicare, and state income tax.</p>
    <div class="calc-grid">
      <div class="field"><label>Annual Gross Salary</label><div class="pfx"><span class="px">$</span><input type="number" id="p-salary" value="75000"/></div></div>
      <div class="field"><label>Pay Frequency</label><select id="p-freq"><option value="26">Bi-Weekly (26/yr)</option><option value="24">Semi-Monthly (24/yr)</option><option value="12">Monthly (12/yr)</option><option value="52">Weekly (52/yr)</option></select></div>
      <div class="field"><label>Filing Status</label><select id="p-status"><option value="single">Single</option><option value="married">Married Filing Jointly</option></select></div>
      <div class="field"><label>State Tax Rate (%)</label><input type="number" id="p-state" value="5" step="0.1"/></div>
      <div class="field"><label>401(k) Contribution (%)</label><input type="number" id="p-401k" value="6" step="0.5"/></div>
      <div class="field"><label>Health Insurance (per paycheck)</label><div class="pfx"><span class="px">$</span><input type="number" id="p-health" value="150"/></div></div>
    </div>
    <button class="calc-btn" onclick="calcPaycheck()">Calculate Take-Home Pay →</button>
    <div class="result-box" id="r-p">
      <div class="rl">💵 Paycheck Breakdown</div>
      <div class="rg">
        <div class="ri"><div class="rn" id="p-takehome">—</div><div class="rs">Take-Home Pay</div></div>
        <div class="ri"><div class="rn" id="p-federal">—</div><div class="rs">Federal Tax</div></div>
        <div class="ri"><div class="rn" id="p-fica">—</div><div class="rs">FICA (SS + Medicare)</div></div>
        <div class="ri"><div class="rn" id="p-annual">—</div><div class="rs">Annual Take-Home</div></div>
      </div>
      <div class="rnote" id="p-note"></div>
    </div>
  </div>

  <div class="calc-card" id="c-k401">
    <div class="calc-icon">📈</div>
    <div class="calc-title">401(k) Growth Calculator</div>
    <p class="calc-desc">See how your 401(k) grows over time with employer match and compound returns.</p>
    <div class="calc-grid">
      <div class="field"><label>Current Balance</label><div class="pfx"><span class="px">$</span><input type="number" id="k-bal" value="25000"/></div></div>
      <div class="field"><label>Annual Salary</label><div class="pfx"><span class="px">$</span><input type="number" id="k-sal" value="80000"/></div></div>
      <div class="field"><label>Your Contribution (%)</label><input type="number" id="k-con" value="10" step="0.5"/></div>
      <div class="field"><label>Employer Match (%)</label><input type="number" id="k-mat" value="4" step="0.5"/></div>
      <div class="field"><label>Expected Annual Return (%)</label><input type="number" id="k-ret" value="7" step="0.5"/></div>
      <div class="field"><label>Years Until Retirement</label><input type="number" id="k-yrs" value="30"/></div>
    </div>
    <button class="calc-btn" onclick="calc401k()">Project My 401(k) →</button>
    <div class="result-box" id="r-k">
      <div class="rl">📈 401(k) Projection</div>
      <div class="rg">
        <div class="ri"><div class="rn" id="k-final">—</div><div class="rs">Projected Balance</div></div>
        <div class="ri"><div class="rn" id="k-yours">—</div><div class="rs">Your Contributions</div></div>
        <div class="ri"><div class="rn" id="k-emp">—</div><div class="rs">Employer Match</div></div>
        <div class="ri"><div class="rn" id="k-grow">—</div><div class="rs">Investment Growth</div></div>
      </div>
      <div class="rnote" id="k-note"></div>
    </div>
  </div>

  <div class="calc-card" id="c-compound">
    <div class="calc-icon">🔢</div>
    <div class="calc-title">Compound Interest Calculator</div>
    <p class="calc-desc">See how your money grows with the power of compounding over time.</p>
    <div class="calc-grid">
      <div class="field"><label>Initial Investment</label><div class="pfx"><span class="px">$</span><input type="number" id="ci-p" value="10000"/></div></div>
      <div class="field"><label>Annual Interest Rate (%)</label><input type="number" id="ci-r" value="7" step="0.1"/></div>
      <div class="field"><label>Compound Frequency</label><select id="ci-n"><option value="1">Annually</option><option value="4">Quarterly</option><option value="12" selected>Monthly</option><option value="365">Daily</option></select></div>
      <div class="field"><label>Monthly Additions</label><div class="pfx"><span class="px">$</span><input type="number" id="ci-add" value="200"/></div></div>
      <div class="slider-wrap full">
        <div class="slider-top"><label>Time Period</label><span class="sv" id="ci-yv">20 Years</span></div>
        <input type="range" id="ci-yrs" min="1" max="50" value="20" oninput="document.getElementById('ci-yv').textContent=this.value+' Years'"/>
      </div>
    </div>
    <button class="calc-btn" onclick="calcCompound()">Calculate Growth →</button>
    <div class="result-box" id="r-ci">
      <div class="rl">💰 Compound Growth</div>
      <div class="rg">
        <div class="ri"><div class="rn" id="ci-final">—</div><div class="rs">Final Balance</div></div>
        <div class="ri"><div class="rn" id="ci-dep">—</div><div class="rs">Total Deposited</div></div>
        <div class="ri"><div class="rn" id="ci-earn">—</div><div class="rs">Interest Earned</div></div>
      </div>
    </div>
  </div>

  <div class="calc-card" id="c-auto">
    <div class="calc-icon">🚗</div>
    <div class="calc-title">Auto Loan Calculator</div>
    <p class="calc-desc">Calculate your monthly car payment and total cost of vehicle ownership.</p>
    <div class="calc-grid">
      <div class="field"><label>Vehicle Price</label><div class="pfx"><span class="px">$</span><input type="number" id="a-price" value="35000"/></div></div>
      <div class="field"><label>Down Payment</label><div class="pfx"><span class="px">$</span><input type="number" id="a-down" value="5000"/></div></div>
      <div class="field"><label>Trade-In Value</label><div class="pfx"><span class="px">$</span><input type="number" id="a-trade" value="0"/></div></div>
      <div class="field"><label>Annual Interest Rate (%)</label><input type="number" id="a-rate" value="6.5" step="0.1"/></div>
      <div class="slider-wrap full">
        <div class="slider-top"><label>Loan Term</label><span class="sv" id="a-tv">60 Months</span></div>
        <input type="range" id="a-term" min="12" max="84" step="12" value="60" oninput="document.getElementById('a-tv').textContent=this.value+' Months'"/>
      </div>
    </div>
    <button class="calc-btn" onclick="calcAuto()">Calculate Car Payment →</button>
    <div class="result-box" id="r-a">
      <div class="rl">🚗 Auto Loan Breakdown</div>
      <div class="rg">
        <div class="ri"><div class="rn" id="a-mo">—</div><div class="rs">Monthly Payment</div></div>
        <div class="ri"><div class="rn" id="a-int">—</div><div class="rs">Total Interest</div></div>
        <div class="ri"><div class="rn" id="a-tot">—</div><div class="rs">Total Cost</div></div>
      </div>
    </div>
  </div>

  <div class="calc-card" id="c-retirement">
    <div class="calc-icon">🎯</div>
    <div class="calc-title">Retirement Savings Calculator</div>
    <p class="calc-desc">Find out how much you need to save monthly to hit your retirement goal.</p>
    <div class="calc-grid">
      <div class="field"><label>Current Age</label><input type="number" id="rt-age" value="35"/></div>
      <div class="field"><label>Retirement Age</label><input type="number" id="rt-ret" value="65"/></div>
      <div class="field"><label>Current Savings</label><div class="pfx"><span class="px">$</span><input type="number" id="rt-sav" value="50000"/></div></div>
      <div class="field"><label>Target Nest Egg</label><div class="pfx"><span class="px">$</span><input type="number" id="rt-goal" value="2000000"/></div></div>
      <div class="field"><label>Expected Annual Return (%)</label><input type="number" id="rt-rtn" value="7" step="0.5"/></div>
      <div class="field"><label>Social Security (monthly)</label><div class="pfx"><span class="px">$</span><input type="number" id="rt-ss" value="1800"/></div></div>
    </div>
    <button class="calc-btn" onclick="calcRetirement()">Plan My Retirement →</button>
    <div class="result-box" id="r-rt">
      <div class="rl">🎯 Retirement Projection</div>
      <div class="rg">
        <div class="ri"><div class="rn" id="rt-mo">—</div><div class="rs">Monthly Savings Needed</div></div>
        <div class="ri"><div class="rn" id="rt-yrs">—</div><div class="rs">Years to Retirement</div></div>
        <div class="ri"><div class="rn" id="rt-proj">—</div><div class="rs">Projected at Retirement</div></div>
        <div class="ri"><div class="rn" id="rt-inc">—</div><div class="rs">Est. Monthly Income</div></div>
      </div>
      <div class="rnote" id="rt-note"></div>
    </div>
  </div>

  <div class="calc-card" id="c-fire">
    <div class="calc-icon">🔥</div>
    <div class="calc-title">FIRE Calculator</div>
