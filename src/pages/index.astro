<script>
var fmtU=n=>'$'+Math.round(n).toLocaleString('en-US');
var fmtK=n=>n>=1000000?'$'+(n/1000000).toFixed(2)+'M':n>=1000?'$'+(n/1000).toFixed(1)+'K':fmtU(n);

function sw(n,btn){
  document.querySelectorAll('.calc-card').forEach(c=>c.classList.remove('active'));
  document.querySelectorAll('.calc-pill').forEach(b=>b.classList.remove('active'));
  document.getElementById('c-'+n).classList.add('active');
  btn.classList.add('active');
}
function tFAQ(btn){btn.closest('.faq-item').classList.toggle('open');}

function calcMortgage(){
  var price=+document.getElementById('m-price').value,down=+document.getElementById('m-down').value;
  var rate=+document.getElementById('m-rate').value/100/12,term=+document.getElementById('m-term').value*12;
  var tax=+document.getElementById('m-tax').value/12,ins=+document.getElementById('m-ins').value/12;
  var loan=price-down; if(!loan||!rate)return;
  var pi=loan*rate*Math.pow(1+rate,term)/(Math.pow(1+rate,term)-1);
  document.getElementById('m-monthly').textContent=fmtU(pi+tax+ins);
  document.getElementById('m-pi').textContent=fmtU(pi);
  document.getElementById('m-ti').textContent=fmtU(pi*term-loan);
  document.getElementById('m-tc').textContent=fmtU(pi*term+down+tax*term+ins*term);
  document.getElementById('m-note').textContent='Loan: '+fmtU(loan)+' | Down: '+(down/price*100).toFixed(1)+'% | P&I: '+fmtU(pi)+'/mo';
  document.getElementById('r-m').classList.add('show');
}
function calcPaycheck(){
  var sal=+document.getElementById('p-salary').value,freq=+document.getElementById('p-freq').value;
  var status=document.getElementById('p-status').value,stRate=+document.getElementById('p-state').value/100;
  var k=+document.getElementById('p-401k').value/100,health=+document.getElementById('p-health').value;
  var k401=sal*k,taxable=sal-k401,fed=0;
  if(status==='single'){
    if(taxable>609350)fed=174238+(taxable-609350)*.37;
    else if(taxable>243725)fed=55374+(taxable-243725)*.35;
    else if(taxable>191950)fed=37104+(taxable-191950)*.32;
    else if(taxable>100525)fed=16290+(taxable-100525)*.24;
    else if(taxable>47150)fed=5426+(taxable-47150)*.22;
    else if(taxable>11600)fed=1160+(taxable-11600)*.12;
    else fed=taxable*.10;
  } else {
    if(taxable>731200)fed=207345+(taxable-731200)*.37;
    else if(taxable>487450)fed=111357+(taxable-487450)*.35;
    else if(taxable>383900)fed=80037+(taxable-383900)*.32;
    else if(taxable>201050)fed=34647+(taxable-201050)*.24;
    else if(taxable>94300)fed=10852+(taxable-94300)*.22;
    else if(taxable>23200)fed=2320+(taxable-23200)*.12;
    else fed=taxable*.10;
  }
  var ss=Math.min(sal,176100)*.062,med=sal*.0145,fica=ss+med;
  var annual=sal-fed-fica-(taxable*stRate)-k401;
  var pp=annual/freq-health;
  document.getElementById('p-takehome').textContent=fmtU(pp);
  document.getElementById('p-federal').textContent=fmtU(fed/freq);
  document.getElementById('p-fica').textContent=fmtU(fica/freq);
  document.getElementById('p-annual').textContent=fmtU(annual-(health*freq));
  document.getElementById('p-note').textContent='Effective federal rate: '+(fed/sal*100).toFixed(1)+'% | 401(k): '+fmtU(k401)+'/yr | State tax: '+fmtU(taxable*stRate/freq)+'/paycheck';
  document.getElementById('r-p').classList.add('show');
}
function calc401k(){
  var bal=+document.getElementById('k-bal').value,sal=+document.getElementById('k-sal').value;
  var con=+document.getElementById('k-con').value/100,mat=+document.getElementById('k-mat').value/100;
  var ret=+document.getElementById('k-ret').value/100,yrs=+document.getElementById('k-yrs').value;
  var ya=Math.min(sal*con,23500),ma=sal*Math.min(mat,con),t=bal,yt=0,mt=0;
  for(var i=0;i<yrs;i++){t=(t+ya+ma)*(1+ret);yt+=ya;mt+=ma;}
  document.getElementById('k-final').textContent=fmtK(t);
  document.getElementById('k-yours').textContent=fmtK(yt);
  document.getElementById('k-emp').textContent=fmtK(mt);
  document.getElementById('k-grow').textContent=fmtK(t-yt-mt-bal);
  document.getElementById('k-note').textContent='Your annual contribution: '+fmtU(ya)+' | Employer match: '+fmtU(ma)+'/yr | 2026 limit: $23,500';
  document.getElementById('r-k').classList.add('show');
}
function calcCompound(){
  var P=+document.getElementById('ci-p').value,r=+document.getElementById('ci-r').value/100;
  var add=+document.getElementById('ci-add').value,t=+document.getElementById('ci-yrs').value;
  var total=P,dep=P;
  for(var i=0;i<t*12;i++){total=total*(1+r/12)+add;dep+=add;}
  document.getElementById('ci-final').textContent=fmtK(total);
  document.getElementById('ci-dep').textContent=fmtK(dep);
  document.getElementById('ci-earn').textContent=fmtK(total-dep);
  document.getElementById('r-ci').classList.add('show');
}
function calcAuto(){
  var price=+document.getElementById('a-price').value,down=+document.getElementById('a-down').value;
  var trade=+document.getElementById('a-trade').value,rate=+document.getElementById('a-rate').value/100/12;
  var term=+document.getElementById('a-term').value,loan=price-down-trade;
  if(!loan||!rate)return;
  var mo=loan*rate*Math.pow(1+rate,term)/(Math.pow(1+rate,term)-1);
  document.getElementById('a-mo').textContent=fmtU(mo);
  document.getElementById('a-int').textContent=fmtU(mo*term-loan);
  document.getElementById('a-tot').textContent=fmtU(mo*term+down+trade);
  document.getElementById('r-a').classList.add('show');
}
function calcRetirement(){
  var age=+document.getElementById('rt-age').value,ret=+document.getElementById('rt-ret').value;
  var sav=+document.getElementById('rt-sav').value,goal=+document.getElementById('rt-goal').value;
  var rtn=+document.getElementById('rt-rtn').value/100,ss=+document.getElementById('rt-ss').value;
  var yrs=ret-age; if(yrs<=0)return;
  var r=rtn/12,n=yrs*12,proj=sav*Math.pow(1+r,n),gap=goal-proj;
  var mo=gap>0?gap*r/(Math.pow(1+r,n)-1):0;
  document.getElementById('rt-mo').textContent=mo>0?fmtU(mo):'On Track!';
  document.getElementById('rt-yrs').textContent=yrs+' yrs';
  document.getElementById('rt-proj').textContent=fmtK(proj);
  document.getElementById('rt-inc').textContent=fmtU(goal*.04/12+ss);
  document.getElementById('rt-note').textContent='Current savings of '+fmtU(sav)+' grows to '+fmtK(proj)+' in '+yrs+' years. Monthly income = 4% rule + $'+ss+'/mo SS.';
  document.getElementById('r-rt').classList.add('show');
}
function calcFIRE(){
  var sp=+document.getElementById('f-sp').value,nw=+document.getElementById('f-nw').value;
  var as=+document.getElementById('f-as').value,ret=+document.getElementById('f-ret').value/100;
  var swr=+document.getElementById('f-swr').value/100,curAge=+document.getElementById('f-age').value;
  var fireNum=sp/swr,port=nw,yrs=0;
  while(port<fireNum&&yrs<60){port=port*(1+ret)+as;yrs++;}
  var sr=(as/(sp+as)*100).toFixed(0);
  document.getElementById('f-num').textContent=fmtK(fireNum);
  document.getElementById('f-yrs').textContent=yrs<60?yrs+' yrs':'60+ yrs';
  document.getElementById('f-fage').textContent=yrs<60?curAge+yrs:'N/A';
  document.getElementById('f-rate').textContent=sr+'%';
  document.getElementById('f-note').textContent='FIRE = Annual spending ÷ '+((swr*100).toFixed(1))+'% SWR = '+fmtK(fireNum)+'. Assumes '+fmtU(as)+'/yr savings at '+((ret*100).toFixed(1))+'% return.';
  document.getElementById('r-f').classList.add('show');
}
function calcCD(){
  var P=+document.getElementById('cd-p').value,apy=+document.getElementById('cd-apy').value/100;
  var t=+document.getElementById('cd-term').value,n=+document.getElementById('cd-freq').value;
  var mat=P*Math.pow(1+apy/n,n*t);
  document.getElementById('cd-mat').textContent=fmtU(mat);
  document.getElementById('cd-int').textContent=fmtU(mat-P);
  document.getElementById('cd-eff').textContent=((Math.pow(1+apy/n,n)-1)*100).toFixed(3)+'%';
  document.getElementById('r-cd').classList.add('show');
}
</script>
</Base>
