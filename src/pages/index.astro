      <div class="field"><label>APY (%)</label><input type="number" id="cd-apy" value="5.1" step="0.05"/></div>
      <div class="field"><label>CD Term</label><select id="cd-term"><option value="0.25">3 Months</option><option value="0.5">6 Months</option><option value="1" selected>1 Year</option><option value="2">2 Years</option><option value="3">3 Years</option><option value="5">5 Years</option></select></div>
      <div class="field"><label>Compound Frequency</label><select id="cd-freq"><option value="365" selected>Daily</option><option value="12">Monthly</option><option value="4">Quarterly</option><option value="1">Annually</option></select></div>
